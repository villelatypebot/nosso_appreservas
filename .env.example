# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SETUP_ENABLED=true
NEXT_PUBLIC_ADMIN_ALLOW_FREE_ACCESS=false

# Whitelabel defaults (the first setup can overwrite these)
NEXT_PUBLIC_BRAND_NAME=Minha Marca
NEXT_PUBLIC_BRAND_SHORT_NAME=Minha Marca
NEXT_PUBLIC_BRAND_TAGLINE=Sistema de reservas profissional e replicável
NEXT_PUBLIC_BRAND_DESCRIPTION=Gerencie reservas, unidades, horários, clientes e integrações em um único painel.
NEXT_PUBLIC_BRAND_SUPPORT_PHONE=
NEXT_PUBLIC_BRAND_SUPPORT_EMAIL=
NEXT_PUBLIC_BRAND_WHATSAPP_PHONE=
NEXT_PUBLIC_BRAND_LOGO_URL=
NEXT_PUBLIC_BRAND_PRIMARY_COLOR=#F47920
NEXT_PUBLIC_BRAND_SECONDARY_COLOR=#C45E0A
NEXT_PUBLIC_RESERVATION_CODE_PREFIX=RS

# Push notifications (optional, but recommended)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@suaempresa.com.br

# Smoke test
SMOKE_TEST_BASE_URL=http://localhost:3000
SMOKE_TEST_UNIT_ID=
SMOKE_TEST_UNIT_SLUG=
SMOKE_TEST_DATE=
SMOKE_TEST_TIME=
SMOKE_TEST_UPDATED_TIME=
SMOKE_TEST_PAX=
SMOKE_TEST_UPDATED_PAX=
SMOKE_TEST_PUSH=0
